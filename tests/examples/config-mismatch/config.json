    "missing_in_code": {
      "display_name": "Missing In Code",
      "description": "Action in config but no decorator in code",
      "input_schema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "output_schema": {
        "type": "object",
        "properties": {}
      }
    }
